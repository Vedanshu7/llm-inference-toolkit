# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Redis (optional — falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Cache settings
CACHE_SIMILARITY_THRESHOLD=0.92   # 0.0–1.0, higher = stricter matching
CACHE_TTL_SECONDS=3600            # 1 hour

# Compression settings
COMPRESSION_THRESHOLD=0.80        # Compress when 80% of context window is used
COMPRESSION_MODEL=gpt-4o-mini     # Cheap model used for summarisation

# Embedding model (used for semantic similarity)
EMBEDDING_MODEL=text-embedding-3-small
